{
  "name": "@zhangziheng/resume",
  "version": "0.1.3",
  "description": "Single-source resume with HTML, PDF, man, JSON, and CLI outputs.",
  "type": "module",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Shadowzzh/resume.git"
  },
  "bin": {
    "resume": "./bin/resume.mjs"
  },
  "files": [
    "README.md",
    "bin/",
    "dist/",
    "renderers/cli/"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "test": "node --test",
    "validate": "node scripts/validate.mjs",
    "build": "node scripts/build.mjs",
    "build:full": "BUILD_PDF=true node scripts/build.mjs",
    "dev": "node scripts/build.mjs",
    "prepublishOnly": "npm test && npm run validate && npm run build:full"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "yaml": "^2.5.1"
  }
}
