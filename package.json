{
  "name": "@zhangziheng/resume",
  "version": "0.1.0",
  "description": "Single-source resume with HTML, PDF, man, JSON, and CLI outputs.",
  "type": "module",
  "private": false,
  "bin": "./bin/resume.mjs",
  "files": [
    "README.md",
    "bin/",
    "dist/",
    "renderers/cli/"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
